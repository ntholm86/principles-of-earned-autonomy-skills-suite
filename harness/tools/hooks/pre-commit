#!/usr/bin/env python3
"""pre-commit hook — enforces Observable Autonomy.

If this commit touches substantive files (skills, tools, principles, README)
but does not stage a corresponding update to .trail/audit-trail.md, the commit is
rejected. The agent (or operator) must record what changed and why.

Override with `git commit --no-verify` — the override itself is auditable
(the absent trail entry will show up at the next verify.py run).

Install:
  bash tools/install-hooks.sh        # macOS / Linux
  pwsh tools/install-hooks.ps1       # Windows
"""
from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path

SUBSTANTIVE = re.compile(r"^(.*/SKILL\.md|PRINCIPLES\.md|README\.md|verify\.py|tools/.*\.py)$")
TRAIL_LOG = ".trail/audit-trail.md"


def staged_files() -> list[str]:
    out = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR"],
        capture_output=True, text=True, check=True,
    )
    return [line for line in out.stdout.splitlines() if line]


def main() -> int:
    files = staged_files()
    substantive = [f for f in files if SUBSTANTIVE.match(f)]
    trail_staged = TRAIL_LOG in files

    if substantive and not trail_staged:
        print("pre-commit: substantive changes staged without a .trail/audit-trail.md update.")
        print()
        print("Files touched:")
        for f in substantive:
            print(f"  - {f}")
        print()
        print("Observable Autonomy requires a trail entry for substantive changes.")
        print("Either:")
        print("  1. Append a structured entry to .trail/audit-trail.md (see trail/SKILL.md), or")
        print("  2. Override with: git commit --no-verify  (auditable; verify.py will catch it)")
        return 1

    repo_root = Path(subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True, text=True, check=True,
    ).stdout.strip())
    verify = repo_root / "verify.py"
    if verify.exists():
        result = subprocess.run([sys.executable, str(verify)], cwd=str(repo_root))
        if result.returncode != 0:
            print()
            print("pre-commit: verify.py failed. Fix the issues above or override with --no-verify.")
            return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
